<!-- Scroll Reveal Observer (uses ft-reveal/ft-visible to avoid Tailwind .visible conflict) -->
<script>
  if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    const ftRevealObserver = new IntersectionObserver(
      (entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting) {
            e.target.classList.add('ft-visible');
          }
        });
      },
      { threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
    );
    document.querySelectorAll('.ft-reveal').forEach((el) => ftRevealObserver.observe(el));
  } else {
    document.querySelectorAll('.ft-reveal').forEach((el) => el.classList.add('ft-visible'));
  }
</script>

